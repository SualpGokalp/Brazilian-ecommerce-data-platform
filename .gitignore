# Ortam değişkenleri (şifreler git'e gitmesin)
.env

# İndirilen CSV verileri (büyük dosyalar, repoya konmaz)
data/*
!data/.gitkeep

# Python
__pycache__/
*.py[cod]
.venv/
venv/
env/

# dbt
dbt/target/
dbt/dbt_packages/
dbt/logs/

# Airflow (otomatik üretilen config gizli anahtar içerir — repoya konmaz)
airflow/config/
airflow/logs/
airflow/plugins/
airflow/*.db
airflow/simple_auth_manager_passwords.json.generated

# Loglar
logs/*
!logs/.gitkeep

# Editör / OS
.vscode/
.idea/
.DS_Store
Thumbs.db
